                                <TextBlock Text="Операции обработки" Margin="0,16,0,0" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                <TextBox x:Name="SopdOperationsTextBox" Margin="0,8,0,0" Height="88" Style="{StaticResource FieldTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />

                                <TextBlock Text="Способ обработки" Margin="0,16,0,0" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                <TextBox x:Name="SopdMethodTextBox" Margin="0,8,0,0" Height="72" Style="{StaticResource FieldTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />

                                <TextBlock Text="Кому передаются данные" Margin="0,16,0,0" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                <TextBox x:Name="SopdTransferToTextBox" Margin="0,8,0,0" Height="72" Style="{StaticResource FieldTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />

                                <TextBlock Text="Описание" Margin="0,16,0,0" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                <TextBox x:Name="SopdDescriptionTextBox" Margin="0,8,0,0" Height="96" Style="{StaticResource FieldTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />

                                <TextBlock Text="Файл СОПД"
                                           Margin="0,20,0,0"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" />
                                <Border x:Name="SopdFileDropBorder"
                                        Background="#09FFFFFF"
                                        BorderBrush="#14C8AEFF"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="16"
                                        Margin="0,12,0,0"
                                        Tag="sopd"
                                        AllowDrop="True"
                                        PreviewDragOver="FileDropSurface_DragOver"
                                        Drop="FileDropSurface_Drop">
                                    <StackPanel>
                                        <TextBlock Text="Word / DOCX" Style="{StaticResource MutedLabelStyle}" FontWeight="Bold" />
                                        <Border x:Name="SopdFileTagBorder" Background="{StaticResource MissingBadgeBrush}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="11" Padding="10,5" Margin="0,10,0,0" HorizontalAlignment="Left">
                                            <TextBlock x:Name="SopdFileTagTextBlock" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="SopdFileCaptionTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Style="{StaticResource MutedLabelStyle}" />
                                        <UniformGrid Columns="4" Margin="0,14,0,0">
                                            <Button x:Name="SopdFileUploadButton" Content="Загрузить" Style="{StaticResource SoftButtonStyle}" Margin="0,0,8,0" Click="SopdFileUploadButton_Click" />
                                            <Button x:Name="SopdFileOpenButton" Content="Открыть" Style="{StaticResource SoftButtonStyle}" Margin="0,0,8,0" Click="SopdFileOpenButton_Click" />
                                            <Button x:Name="SopdFileDownloadButton" Content="Скачать" Style="{StaticResource SoftButtonStyle}" Margin="0,0,8,0" Click="SopdFileDownloadButton_Click" />
                                            <Button x:Name="SopdFileDeleteButton" Content="Удалить" Style="{StaticResource SoftButtonStyle}" Click="SopdFileDeleteButton_Click" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel x:Name="DocumentActionsPanel" Grid.Row="2" Margin="0,18,0,0">
                        <Button x:Name="SaveDocumentButton"
                                Content="Сохранить документ"
                                Style="{StaticResource SolidButtonStyle}"
                                Click="SaveDocumentButton_Click" />
                        <Button x:Name="DeleteDocumentButton"
                                Content="Удалить документ"
                                Style="{StaticResource DangerButtonStyle}"
                                Margin="0,12,0,0"
                                Click="DeleteDocumentButton_Click" />
                    </StackPanel>

                    <StackPanel x:Name="SopdActionsPanel" Grid.Row="2" Margin="0,18,0,0" Visibility="Collapsed">
                        <Button x:Name="SaveSopdButton"
                                Content="Сохранить карточку"
                                Style="{StaticResource SolidButtonStyle}"
                                Click="SaveSopdButton_Click" />
                        <Button x:Name="DeleteSopdButton"
                                Content="Удалить карточку"
                                Style="{StaticResource DangerButtonStyle}"
                                Margin="0,12,0,0"
                                Click="DeleteSopdButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>

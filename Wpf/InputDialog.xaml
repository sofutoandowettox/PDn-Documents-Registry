<Window x:Class="PDnDocuments.Wpf.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод"
        Width="520"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#22000000"
            CornerRadius="30"
            Padding="1">
        <Border Background="{StaticResource SurfaceCardBrush}"
                BorderBrush="{StaticResource StrokeStrongBrush}"
                BorderThickness="1"
                CornerRadius="28"
                Padding="24">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="56"
                            Height="56"
                            Background="#20C8AEFF"
                            BorderBrush="{StaticResource StrokeStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            VerticalAlignment="Top">
                        <TextBlock Text="+"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}" />
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="TitleTextBlock"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock x:Name="PromptTextBlock"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource MutedLabelStyle}" />
                    </StackPanel>
                </Grid>

                <Border Margin="0,22,0,0"
                        Background="{StaticResource SurfaceElevatedBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Название"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSoftBrush}" />
                        <TextBox x:Name="ValueTextBox"
                                 Margin="0,10,0,0"
                                 Height="48"
                                 Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBlock Text="Название можно будет изменить позже в разделе компаний и разделов."
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource MutedLabelStyle}" />
                    </StackPanel>
                </Border>

                <Grid Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Отмена"
                            IsCancel="True"
                            Style="{StaticResource SoftButtonStyle}"
                            Click="CancelButton_Click" />
                    <Button Grid.Column="2"
                            Content="Сохранить"
                            IsDefault="True"
                            Style="{StaticResource SolidButtonStyle}"
                            Click="OkButton_Click" />
                </Grid>
            </StackPanel>
        </Border>
    </Border>
</Window>
